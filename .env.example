TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6
LOG_LEVEL=INFO
ENVIRONMENT=development

# Marketing groups — bot responds to /quote and mentions here.
# Comma-separated chat IDs (negative for groups). Get from getUpdates URL.
MARKETING_CHAT_IDS=-1001111111111

# Admin groups — bot mirrors every marketing inquiry here with feedback buttons.
# Admins can also /quote here directly. First ID is the mirror target.
ADMIN_CHAT_IDS=-1002222222222

# Comma-separated Telegram user IDs allowed to use admin commands +
# give feedback / approve KB updates. DM @userinfobot to get yours.
ADMIN_USER_IDS=123456789

# Bot username WITHOUT the @ prefix
BOT_USERNAME=ip_marketing_bot

# ─── Google Sheets backend ──────────────────────────────────────────────
# 1. Create Sheet at sheets.google.com, copy the long ID from the URL
#    (the part between /d/ and /edit)
GSHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789ABCDEFG

# 2. Path to the service account JSON file downloaded from Google Cloud
GOOGLE_CREDENTIALS_FILE=secrets/service_account.json

# 3. Refresh interval for KB cache (seconds). Set lower if you edit KB often.
KB_REFRESH_SECONDS=600
